{
  "mcpServers": {
    "pdf-rescue": {
      "command": "uv",
      "args": ["run", "--locked", "--extra", "ocr", "python", "-B", "scripts/start_mcp.py"],
      "cwd": "{{PROJECT_ROOT}}",
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONLEGACYWINDOWSSTDIO": "0"
      }
    }
  }
}
